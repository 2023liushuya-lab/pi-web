{
  "name": "pi-web",
  "version": "0.1.0",
  "description": "Enhanced web UI for the pi coding agent — built on the pi-web framework",
  "license": "MIT",
  "author": "2023liushuya-lab",
  "repository": {
    "type": "git",
    "url": "https://github.com/2023liushuya-lab/pi-web"
  },
  "bin": {
    "pi-web": "bin/pi-web.js"
  },
  "files": [
    "bin",
    ".next",
    "!.next/cache",
    "!.next/dev",
    "!.next/**/*.js.map",
    "public",
    "next.config.ts",
    "package.json"
  ],
  "scripts": {
    "dev": "next dev -p 32000 --webpack",
    "build": "next build --webpack",
    "start": "next start -p 32000",
    "lint": "eslint .",
    "release": "npm version patch --no-git-tag-version && npm run build && npm publish --access public"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.0",
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "@lobehub/icons": "^5.6.0",
    "@next/swc-wasm-nodejs": "16.2.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "katex": "^0.16.47",
    "mammoth": "^1.12.0",
    "mermaid": "^11.14.0",
    "next": "16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "8",
    "tailwindcss": "3",
    "typescript": "5.9.3"
  }
}
